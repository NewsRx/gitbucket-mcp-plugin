{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".opencode/guidelines/*.md"
  ],
  "plugin": [
    "superpowers@git+https://github.com/NewsRx/opencode-gitbucket-superpowers.git"
  ],
  "mcp": {
    "the-notebook-mcp": {
      "type": "local",
      "command": [
        "uvx",
        "--with",
        "fastmcp==2.3.3",
        "the-notebook-mcp",
        "start",
        "--allow-root",
        "{env:PWD}",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "srclight": {
      "type": "local",
      "command": [
        "uvx",
        "srclight",
        "serve",
        "--transport",
        "stdio"
      ],
      "enabled": true,
      "environment": {
        "OLLAMA_BASE_URL": "http://localhost:11434"
      }
    }
  }
}